# ============================================================
# Prismer.AI — Environment Configuration
# ============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start with:
#   cd docker && docker compose -f docker-compose.openclaw.yml up --build -d
#

# ==============================================================================
# Required
# ==============================================================================

# Database (SQLite, persisted via Docker volume)
DATABASE_URL="file:/app/prisma/dev.db"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-string"
NEXTAUTH_URL=http://localhost:3000

# ==============================================================================
# AI Service (required for chat / agent features)
# ==============================================================================

# Any OpenAI-compatible API (e.g. OpenAI, Azure, vLLM, Ollama, LiteLLM)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE_URL=https://api.openai.com/v1
AGENT_DEFAULT_MODEL=gpt-4o

# Client-side (browser — for AI-Native PDF Reader)
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here
NEXT_PUBLIC_OPENAI_API_BASE_URL=https://api.openai.com/v1
NEXT_PUBLIC_AGENT_DEFAULT_MODEL=gpt-4o

# ==============================================================================
# Optional — Anthropic (if using Claude models)
# ==============================================================================

# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ==============================================================================
# Data Source
# ==============================================================================

# false = use local data (public/data/output/), no MySQL needed
# true  = use remote MySQL database (requires REMOTE_MYSQL_* below)
USE_REMOTE_PAPERS=false

# ==============================================================================
# Optional — Remote MySQL (only if USE_REMOTE_PAPERS=true)
# ==============================================================================

# REMOTE_MYSQL_HOST=
# REMOTE_MYSQL_PORT=3306
# REMOTE_MYSQL_USER=
# REMOTE_MYSQL_PASSWORD=
# REMOTE_MYSQL_DATABASE=

# ==============================================================================
# Optional — OAuth Login
# ==============================================================================

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==============================================================================
# Optional — S3 Storage (for file uploads)
# ==============================================================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ==============================================================================
# Optional — CDN
# ==============================================================================

# CDN_DOMAIN=
# NEXT_PUBLIC_CDN_DOMAIN=

# ==============================================================================
# Optional — Container / Agent Overrides
# ==============================================================================

# OPENCLAW_GATEWAY_TOKEN=prismer-dev-token
# PRISMER_IM_SERVER_URL=http://prismer-web:3456
# PRISMER_API_BASE_URL=http://prismer-web:3000
# PRISMER_AGENT_TOKEN=dev-token
# PRISMER_CONVERSATION_ID=test-conversation
# PRISMER_AGENT_ID=default
