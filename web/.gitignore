# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing — all output under tests/output/ (test code is committed, output is not)
tests/output/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.docker.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/data/output/
/src/generated/prisma
public/pdfjs

# Mobile dev temp files
.mobile-dev/
*.pid

# Python cache
__pycache__/
*.pyc
*.pyo

# Session data (dev only)
data/sessions/*.json
!data/sessions/.gitkeep
public/data/latex-output/

/coverage

# Prisma dev database (SQLite)
prisma/dev.db
prisma/dev.db-journal
