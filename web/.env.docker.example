# ===========================================
# Prismer Local Mode Configuration
# ===========================================
#
# Copy to .env:  cp .env.docker.example .env
# Then edit and add your API key.

# --- Required ---
OPENAI_API_KEY=sk-your-key-here

# --- Database (SQLite for local dev) ---
DATABASE_URL="file:./prisma/dev.db"

# --- Optional: LLM Configuration ---
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# AGENT_DEFAULT_MODEL=gpt-4o

# --- Optional: Client-side AI (PDF Reader features) ---
# NEXT_PUBLIC_OPENAI_API_KEY=
# NEXT_PUBLIC_OPENAI_API_BASE_URL=https://api.openai.com/v1
# NEXT_PUBLIC_AGENT_DEFAULT_MODEL=gpt-4o-mini

# --- Optional: Data Source ---
# USE_REMOTE_PAPERS=false
# REMOTE_MYSQL_HOST=
# REMOTE_MYSQL_PORT=3306
# REMOTE_MYSQL_USER=
# REMOTE_MYSQL_PASSWORD=
# REMOTE_MYSQL_DATABASE=

# --- Optional: S3 Storage (for file uploads) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# --- Optional: CDN (for paper OCR/thumbnails) ---
# CDN_DOMAIN=

# --- Optional: Dev User ---
# DEV_USER_EMAIL=dev@localhost

# --- Optional: Agent Container ---
STATIC_AGENT_ENABLED=true
STATIC_AGENT_ID=default
STATIC_AGENT_CONTAINER_ID=prismer-agent
CONTAINER_GATEWAY_URL=http://localhost:16888
