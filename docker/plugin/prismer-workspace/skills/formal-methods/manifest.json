{
  "_source": "Canonical source: /skills/formal-methods/manifest.json",
  "id": "formal-methods",
  "name": "Formal Methods",
  "version": "1.0.0",
  "description": "Formal verification with Lean 4, Coq, and Z3 SMT solver. Type-check proofs, compile theories, and solve satisfiability problems.",
  "category": "general",
  "author": "Prismer Team",
  "repository": "https://github.com/LuminPulse-AI/Prismer",
  "tools": [
    {
      "name": "lean_check",
      "description": "Type-check Lean 4 code",
      "parameters": {
        "code": { "type": "string", "description": "Lean 4 source code", "required": true },
        "filename": { "type": "string", "description": "Source filename", "required": false }
      }
    },
    {
      "name": "coq_check",
      "description": "Check a Coq proof for correctness",
      "parameters": {
        "code": { "type": "string", "description": "Coq source code", "required": true },
        "filename": { "type": "string", "description": "Source filename", "required": false }
      }
    },
    {
      "name": "coq_compile",
      "description": "Compile a Coq file to .vo",
      "parameters": {
        "code": { "type": "string", "description": "Coq source code", "required": true },
        "filename": { "type": "string", "description": "Source filename", "required": false }
      }
    },
    {
      "name": "z3_solve",
      "description": "Solve SMT satisfiability problem",
      "parameters": {
        "formula": { "type": "string", "description": "SMT-LIB2 formula", "required": false },
        "code": { "type": "string", "description": "Z3 Python code", "required": false },
        "format": { "type": "string", "description": "smt2 or python", "required": false }
      }
    },
    {
      "name": "prover_status",
      "description": "Check available provers and versions",
      "parameters": {}
    }
  ],
  "dependencies": [],
  "builtin": true
}
